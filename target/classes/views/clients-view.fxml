<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.company.workorders.controller.ClientsController"
            style="-fx-background-color: #f7f4f2; -fx-fit-to-width: true;">
    <VBox spacing="24" style="-fx-background-color: #f7f4f2;">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>

        <!-- PAGE HEADER -->
        <VBox spacing="8">
            <Label text="Gestion des Clients" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #410007;"/>
            <Label text="Créez, modifiez et gérez les fiches clients" style="-fx-font-size: 13; -fx-text-fill: #666666;"/>
        </VBox>

        <!-- FORM SECTION -->
        <VBox spacing="16" style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 4, 0, 0, 1);">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <VBox spacing="4">
                <Label text="NOUVEAU CLIENT" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                <Separator/>
            </VBox>

            <!-- FORM GRID -->
            <HBox spacing="20">
                <!-- LEFT COLUMN -->
                <VBox spacing="14" HBox.hgrow="ALWAYS">
                    <!-- COMPANY -->
                    <VBox spacing="6">
                        <Label text="Nom de la Société" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                        <TextField fx:id="companyField" promptText="Ex: ACME Services SARL"
                                   style="-fx-padding: 10px; -fx-font-size: 12px; -fx-border-color: #e8e8e8; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    </VBox>

                    <!-- PHONE -->
                    <VBox spacing="6">
                        <Label text="Téléphone" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                        <TextField fx:id="phoneField" promptText="Ex: +33 1 23 45 67 89"
                                   style="-fx-padding: 10px; -fx-font-size: 12px; -fx-border-color: #e8e8e8; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    </VBox>

                    <!-- ADDRESS -->
                    <VBox spacing="6">
                        <Label text="Adresse" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                        <TextField fx:id="addressField" promptText="Ex: 123 Rue de la Paix, 75000 Paris"
                                   style="-fx-padding: 10px; -fx-font-size: 12px; -fx-border-color: #e8e8e8; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                    </VBox>
                </VBox>
            </HBox>

            <!-- ACTION BUTTONS -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button fx:id="resetButton" text="Réinitialiser" onAction="#handleResetForm"
                        style="-fx-padding: 10 24; -fx-font-size: 12; -fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-width: 1; -fx-text-fill: #2d2d2d; -fx-cursor: hand;"/>
                <Button fx:id="deleteButton" text="Supprimer" onAction="#handleDeleteClient"
                        style="-fx-padding: 10 24; -fx-font-size: 12; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSaveClient"
                        style="-fx-padding: 10 24; -fx-font-size: 12; -fx-background-color: #c8102e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- LIST SECTION -->
        <VBox spacing="16" style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 4, 0, 0, 1);">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <VBox spacing="4">
                <Label text="LISTE DES CLIENTS" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>
                <Label text="Consultez et modifiez les clients existants" style="-fx-font-size: 11; -fx-text-fill: #999999;"/>
            </VBox>

            <!-- SEARCH BAR -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 12; -fx-background-color: #f7f4f2; -fx-border-radius: 4;">
                <Label text="🔍" style="-fx-font-size: 14;"/>
                <TextField fx:id="searchField" promptText="Rechercher par nom ou téléphone..." HBox.hgrow="ALWAYS"
                           style="-fx-padding: 8 12; -fx-font-size: 12px; -fx-border-width: 0; -fx-background-color: transparent;"/>
                <Button text="Chercher" onAction="#handleSearch"
                        style="-fx-padding: 8 16; -fx-font-size: 11; -fx-background-color: #c8102e; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>

            <!-- TABLE -->
            <TableView fx:id="clientTable" prefHeight="400" style="-fx-font-size: 12px;">
                <columns>
                    <TableColumn fx:id="companyColumn" text="Société" prefWidth="280"/>
                    <TableColumn fx:id="phoneColumn" text="Téléphone" prefWidth="180"/>
                    <TableColumn fx:id="addressColumn" text="Adresse" prefWidth="320"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>