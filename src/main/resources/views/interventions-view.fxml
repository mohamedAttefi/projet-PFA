<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.company.workorders.controller.InterventionsController"
            fitToWidth="true"
            style="-fx-background-color: #f7f4f2;">
    <VBox spacing="20" style="-fx-background-color: #f7f4f2;">
        <padding><Insets top="24" right="24" bottom="28" left="24"/></padding>

        <VBox spacing="4">
            <Label text="Liste des Interventions" style="-fx-font-size: 28; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
            <Label text="Gérez et suivez toutes vos interventions de maintenance."
                   style="-fx-font-size: 13; -fx-text-fill: #7d6d68;"/>
        </VBox>

        <VBox spacing="14" style="-fx-background-color: white; -fx-border-color: #ebe2de; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 16;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Rechercher une intervention..." HBox.hgrow="ALWAYS"
                           onAction="#handleSearch"
                           style="-fx-background-color: #f7f4f2; -fx-background-radius: 8; -fx-border-color: #f0e6e2; -fx-border-radius: 8; -fx-padding: 10 14;"/>
                <ComboBox fx:id="filterStatusBox" promptText="Statut: Tous" onAction="#handleSearch" prefWidth="120"/>
                <ComboBox fx:id="filterPriorityBox" promptText="Priorité: Toutes" onAction="#handleSearch" prefWidth="130"/>
                <ComboBox fx:id="filterTechnicianBox" promptText="Technicien" onAction="#handleSearch" prefWidth="160"/>
                <DatePicker fx:id="startDatePicker" promptText="Date début" onAction="#handleSearch" prefWidth="120"/>
                <DatePicker fx:id="endDatePicker" promptText="Date fin" onAction="#handleSearch" prefWidth="120"/>
            </HBox>
            <HBox spacing="10">
                <Button text="+ Nouvelle Intervention" onAction="#createNewIntervention"
                        style="-fx-background-color: #c8102e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-cursor: hand;"/>
                <Button text="📊 Exporter CSV" onAction="#handleExportToCSV"
                        style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-text-fill: #2d2d2d; -fx-padding: 10 18; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <VBox spacing="14" style="-fx-background-color: white; -fx-border-color: #ebe2de; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20;">
            <TableView fx:id="interventionTable" prefHeight="400">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="titleColumn" text="TITRE" prefWidth="250"/>
                    <TableColumn fx:id="clientColumn" text="CLIENT" prefWidth="180"/>
                    <TableColumn fx:id="priorityColumn" text="PRIORITÉ" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="STATUT" prefWidth="100"/>
                    <TableColumn fx:id="technicianColumn" text="TECHNICIEN" prefWidth="140"/>
                    <TableColumn fx:id="dateColumn" text="DATE" prefWidth="100"/>
                    <TableColumn fx:id="actionsColumn" text="ACTIONS" prefWidth="120"/>
                </columns>
            </TableView>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label fx:id="paginationInfoLabel" text="Affichage de 0 à 0 sur 0 interventions" style="-fx-font-size: 12; -fx-text-fill: #7d6d68;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="←" onAction="#handlePreviousPage" style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-cursor: hand;"/>
                <Button text="1" onAction="#handlePage1" fx:id="page1Button" style="-fx-background-color: #c8102e; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="2" onAction="#handlePage2" fx:id="page2Button" style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-cursor: hand;"/>
                <Button text="3" onAction="#handlePage3" fx:id="page3Button" style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-cursor: hand;"/>
                <Button text="→" onAction="#handleNextPage" style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-cursor: hand;"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Actions rapides:" style="-fx-font-size: 12; -fx-text-fill: #7d6d68;"/>
                <Button text="Voir détails" onAction="#handleViewDetails" 
                        style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-text-fill: #2d2d2d; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Button text="Modifier" onAction="#handleEditIntervention" 
                        style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-text-fill: #2d2d2d; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Button text="Assigner technicien" onAction="#handleAssignTechnician" 
                        style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-text-fill: #2d2d2d; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Button text="Changer statut" onAction="#handleChangeStatus" 
                        style="-fx-background-color: white; -fx-border-color: #e1d7d3; -fx-text-fill: #2d2d2d; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Button text="Supprimer" onAction="#handleDeleteIntervention" 
                        style="-fx-background-color: white; -fx-border-color: #f1c4c4; -fx-text-fill: #c8102e; -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS" style="-fx-background-color: #fff8f8; -fx-background-radius: 10; -fx-padding: 14;">
                    <Label text="URGENCES" style="-fx-font-size: 10; -fx-text-fill: #c8102e;"/>
                    <Label text="3" style="-fx-font-size: 24; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS" style="-fx-background-color: #fffaf1; -fx-background-radius: 10; -fx-padding: 14;">
                    <Label text="EN ATTENTE" style="-fx-font-size: 10; -fx-text-fill: #f39c12;"/>
                    <Label text="12" style="-fx-font-size: 24; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS" style="-fx-background-color: #f3fbf6; -fx-background-radius: 10; -fx-padding: 14;">
                    <Label text="CLÔTURÉES (24H)" style="-fx-font-size: 10; -fx-text-fill: #27ae60;"/>
                    <Label text="8" style="-fx-font-size: 24; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>