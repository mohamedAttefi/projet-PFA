<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.company.workorders.controller.NotificationsController"
            fitToWidth="true"
            style="-fx-background-color: #f7f4f2;">
    <VBox spacing="20" style="-fx-background-color: #f7f4f2;">
        <padding><Insets top="24" right="24" bottom="28" left="24"/></padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label text="Notifications" style="-fx-font-size: 28; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                <Label text="Consultez toutes les alertes et les mises à jour du système."
                       style="-fx-font-size: 13; -fx-text-fill: #7d6d68;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField promptText="Rechercher une notification..." prefWidth="320"
                       style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #ebe2de; -fx-border-radius: 8; -fx-padding: 10 14;"/>
            <Button text="Aide" style="-fx-background-color: transparent; -fx-text-fill: #7d6d68;"/>
        </HBox>

        <HBox spacing="18">
            <VBox spacing="14" prefWidth="280"
                  style="-fx-background-color: white; -fx-border-color: #ebe2de; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 18;">
                <Label text="Statistiques" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #fff2f2; -fx-background-radius: 10; -fx-padding: 12;">
                    <Label text="⚠" style="-fx-font-size: 18; -fx-text-fill: #c8102e;"/>
                    <VBox spacing="2">
                        <Label text="Urgences" style="-fx-text-fill: #7d6d68;"/>
                        <Label fx:id="urgentCountLabel" text="00" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                    </VBox>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #eef4ff; -fx-background-radius: 10; -fx-padding: 12;">
                    <Label text="🗂" style="-fx-font-size: 18; -fx-text-fill: #3b5b93;"/>
                    <VBox spacing="2">
                        <Label text="En cours" style="-fx-text-fill: #7d6d68;"/>
                        <Label fx:id="inProgressCountLabel" text="00" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                    </VBox>
                </HBox>
                <VBox spacing="8" style="-fx-background-color: #c8102e; -fx-background-radius: 12; -fx-padding: 18;">
                    <Label text="Support Technique" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: white;"/>
                    <Label text="Besoin d'aide pour configurer vos alertes ?" style="-fx-text-fill: rgba(255,255,255,0.85);" wrapText="true"/>
                    <Button text="CONTACTER L'EXPERT" style="-fx-background-color: white; -fx-text-fill: #c8102e; -fx-font-weight: bold;"/>
                </VBox>
            </VBox>

            <VBox spacing="14" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-border-color: #ebe2de; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 18;">
                <HBox>
                    <VBox spacing="2">
                        <Label text="Centre d'activité" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #2d2d2d;"/>
                        <Label text="Gérez vos alertes et le suivi des interventions en temps réel." style="-fx-font-size: 11; -fx-text-fill: #7d6d68;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Paramètres de notification" onAction="#handleSettings"
                            style="-fx-background-color: white; -fx-border-color: #ebe2de; -fx-text-fill: #2d2d2d;"/>
                    <Button text="Test notification" onAction="#handleCreateTestNotification"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Button text="Tout marquer comme lu" onAction="#handleMarkAllRead"
                            style="-fx-background-color: #c8102e; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
                
                <VBox fx:id="notificationList" spacing="12">
                    <!-- Notifications will be dynamically loaded here -->
                </VBox>
            </VBox>
        </HBox>
        
        <!-- Floating Action Button -->
        <HBox alignment="BOTTOM_RIGHT">
            <Button text="+" prefWidth="56" prefHeight="56"
                    style="-fx-background-color: #c8102e; -fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold; -fx-background-radius: 28; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</ScrollPane>