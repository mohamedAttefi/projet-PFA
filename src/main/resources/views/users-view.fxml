<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.company.workorders.controller.UsersController"
      spacing="16" style="-fx-background-color: #f7f4f2;">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
    <Label text="Gestion des utilisateurs" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #410007;"/>
    <HBox spacing="16">
        <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #edd7d4; -fx-border-radius: 14;" prefWidth="360">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <Label text="Créer un utilisateur" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <TextField fx:id="nameField" promptText="Nom"/>
            <TextField fx:id="emailField" promptText="Email"/>
            <PasswordField fx:id="passwordField" promptText="Mot de passe"/>
            <ComboBox fx:id="roleBox" promptText="Rôle"/>
            <Button text="Enregistrer" onAction="#handleSaveUser" maxWidth="Infinity"/>
        </VBox>
        <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #edd7d4; -fx-border-radius: 14;" prefWidth="720">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <Label text="Utilisateurs existants" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <TableView fx:id="userTable" prefHeight="540">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Nom" prefWidth="220"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="260"/>
                    <TableColumn fx:id="roleColumn" text="Rôle" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>