<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.company.workorders.controller.AppShellController"
            prefWidth="1600.0" prefHeight="900.0"
            style="-fx-background-color: #f7f4f2;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-background-color: linear-gradient(to right, #9e001f 0%, #c8102e 100%); -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 8, 0, 0, 2);">
            <padding>
                <Insets top="18" right="32" bottom="18" left="32"/>
            </padding>

            <!-- LOGO & TITLE -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                                <ImageView fitWidth="44" fitHeight="44" preserveRatio="true" smooth="true">
                                    <image>
                                        <Image url="/images/canal_logo.png" />
                                    </image>
                                </ImageView>
                                <VBox spacing="2">
                                        <Label text="CANAL INFORMATIQUE" 
                                                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-letter-spacing: -0.5;"/>
                                        <Label text="Gestion des Interventions" 
                                                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 11;"/>
                                </VBox>
                        </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- USER SECTION -->
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label text="Connecté en tant que" 
                       style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 10;"/>
                <Label fx:id="userLabel" text="Utilisateur" 
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
            </VBox>

            <Separator style="-fx-orientation: vertical; -fx-padding: 8px 0; -fx-stroke: rgba(255,255,255,0.3);"/>

            <!-- NOTIFICATIONS ICON -->
            <Button text="🔔" onAction="#loadNotifications"
                    style="-fx-font-size: 16; -fx-padding: 8 12; -fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="4" prefWidth="280"
              style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="32" right="0" bottom="32" left="0"/>
            </padding>

            <!-- SIDEBAR HEADER -->
            <Label text="MENU PRINCIPAL" 
                   style="-fx-font-size: 11; -fx-text-fill: #999999; -fx-font-weight: bold; -fx-padding: 0 16px;"/>

            <!-- NAVIGATION BUTTONS -->
            <Button fx:id="dashboardBtn" text="📊 Tableau de bord" onAction="#loadDashboard" 
                    maxWidth="Infinity" style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #2d2d2d; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="interventionsBtn" text="⚙️ Interventions" onAction="#loadInterventions" 
                    maxWidth="Infinity" style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #2d2d2d; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="clientsBtn" text="👥 Clients" onAction="#loadClients" 
                    maxWidth="Infinity" style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #2d2d2d; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="usersBtn" text="👤 Utilisateurs" onAction="#loadUsers" 
                    maxWidth="Infinity" style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #2d2d2d; -fx-font-size: 13; -fx-cursor: hand;"/>
            
            <Separator style="-fx-padding: 8 0;"/>

            <!-- ADDITIONAL MENU -->
            <Label text="AUTRES" 
                   style="-fx-font-size: 11; -fx-text-fill: #999999; -fx-font-weight: bold; -fx-padding: 8 16 0 16;"/>

            <Button fx:id="notificationsBtn" text="🔔 Notifications" onAction="#loadNotifications" 
                    maxWidth="Infinity" style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #2d2d2d; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="historyBtn" text="📜 Historique" onAction="#loadHistory" 
                    maxWidth="Infinity" style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #2d2d2d; -fx-font-size: 13; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- FOOTER -->
            <Separator/>
            <Button fx:id="logoutBtn" text="🚪 Déconnexion" onAction="#handleLogout" maxWidth="Infinity"
                    style="-fx-padding: 14 16; -fx-text-alignment: left; -fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-font-size: 13; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Label text="© 2026 Canal Informatique" 
                   style="-fx-font-size: 10; -fx-text-fill: #999999; -fx-padding: 16 16 0 16;"/>
        </VBox>
    </left>

    <!-- CONTENT AREA -->
    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: #f7f4f2;"/>
    </center>
</BorderPane>