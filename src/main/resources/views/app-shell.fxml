<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.company.workorders.controller.AppShellController"
            prefWidth="1600.0" prefHeight="900.0"
            style="-fx-background-color: #f7f4f2;">

    <top>
        <HBox spacing="18" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-border-color: #e9e1dd; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="14" right="24" bottom="14" left="24"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                    <image>
                        <Image url="/images/canal_logo.png"/>
                    </image>
                </ImageView>
                <VBox spacing="1">
                    <Label text="Canal Informatique" style="-fx-text-fill: #c8102e; -fx-font-size: 18; -fx-font-weight: 800;"/>
                    <Label text="Gestion de maintenance" style="-fx-text-fill: #7d6d68; -fx-font-size: 10; -fx-letter-spacing: 1;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Rechercher une intervention, un client..."
                       prefWidth="420"
                       style="-fx-background-color: #f7f4f2; -fx-background-radius: 8; -fx-border-color: #f0e6e2; -fx-border-radius: 8; -fx-padding: 10 14;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Aide" onAction="#loadHistory"
                    style="-fx-background-color: transparent; -fx-text-fill: #6f5651; -fx-cursor: hand;"/>
            <Button text="🔔" onAction="#loadNotifications"
                    style="-fx-background-color: transparent; -fx-font-size: 16; -fx-text-fill: #6f5651; -fx-cursor: hand;"/>
            <Button text="⚙" onAction="#loadProfile"
                    style="-fx-background-color: transparent; -fx-font-size: 16; -fx-text-fill: #6f5651; -fx-cursor: hand;"/>

            <Button fx:id="profileBtn" text="Jean Dupont" onAction="#loadProfile"
                    style="-fx-background-color: transparent; -fx-padding: 0; -fx-cursor: hand; -fx-text-fill: #2d2d2d; -fx-font-weight: bold;"/>
            <Label fx:id="userLabel" text="Utilisateur" style="-fx-text-fill: #7d6d68; -fx-font-size: 11;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="12" prefWidth="250"
              style="-fx-background-color: white; -fx-border-color: #ebe2de; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>

            <VBox spacing="2" style="-fx-padding: 0 6 10 6;">
                <Label text="Canal Informatique" style="-fx-text-fill: #c8102e; -fx-font-size: 16; -fx-font-weight: 800;"/>
                <Label text="Gestion de maintenance" style="-fx-text-fill: #7d6d68; -fx-font-size: 10; -fx-letter-spacing: 1;"/>
            </VBox>

            <Label text="Navigation" style="-fx-text-fill: #a0938e; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 12 8 4 8;"/>
            <Button fx:id="dashboardBtn" text="Tableau de bord" onAction="#loadDashboard" maxWidth="Infinity"
                    style="-fx-background-color: #fef5f7; -fx-text-fill: #c8102e; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
            <Button fx:id="interventionsBtn" text="Interventions" onAction="#loadInterventions" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4f4743; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
            <Button fx:id="clientsBtn" text="Clients" onAction="#loadClients" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4f4743; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
            <Button fx:id="notificationsBtn" text="Notifications" onAction="#loadNotifications" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4f4743; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
            <Button fx:id="historyBtn" text="Historique" onAction="#loadHistory" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4f4743; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
            <Button fx:id="usersBtn" text="Utilisateurs" onAction="#loadUsers" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4f4743; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
            <Button fx:id="profileBtn" text="Profil" onAction="#loadProfile" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #4f4743; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" style="-fx-padding: 12 6 0 6;">
                <Button fx:id="logoutBtn" text="Déconnexion" onAction="#handleLogout" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #c8102e; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 12 14; -fx-border-color: transparent;"/>
                <Label text="© 2026 Canal Informatique" style="-fx-text-fill: #a0938e; -fx-font-size: 10; -fx-padding: 0 8;"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: #f7f4f2;"/>
    </center>
</BorderPane>